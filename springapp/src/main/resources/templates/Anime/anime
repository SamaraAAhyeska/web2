<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
  <th:block
    th:replace="~{/../fragments/head :: head('Listar Anime')}"
  ></th:block>
  <body>
    <th:block th:replace="~{/../fragments/head :: header}"></th:block>
    <div class="container">
      <h1>Listagem de Anime </h1>
      <table class="table table-striped">
        <thead>
          <tr>
            <th scope="col">Nome</th>
            <th scope="col">Gênero</th>
            <th scope="col">Ano</th>
            <th scope="col">Descrição</th>
            <th scope="col">Excluir</th>
            <th scope="col">Editar</th>
          </tr>
        </thead>
        <tbody>
          <tr th:each="anime : ${animesList}">
            <td scope="row" th:text="${anime.name}"></td>
            <td scope="row" th:text="${anime.genero}"></td>
            <td scope="row" th:text="${anime.ano}"></td>
             <td scope="row" th:text="${anime.description}"></td>
            <td>
              <a th:href="@{/anime/edit/{id}(id=${anime.id})}">Editar</a>
            </td>
            <td>
              <a th:href="@{/anime/delete/{id}(id=${anime.id})}">Deletar</a>
            </td>
          </tr>
        </tbody>
      </table>
      <div class="row">
        <a th:href="@{/anime/create}">
          <button sec:authorize="hasAuthority('Admin')" class="btn btn-primary">Cadastrar Anime</button>
        </a>
      </div>
    </div>
	<th:block th:replace="~{/../fragments/footer :: footer}"></th:block>
  </body>
</html>